# PDF OCR RAG Accelerator – configuration template
# Copy to config.yml and set values for your environment.
# In Databricks, set these via notebook widgets in 01-ocr-and-adapter and 02-chunk-index.

# Unity Catalog
catalog: main
schema: default

# --- 01-ocr-and-adapter: OCR + adapter ---
# Directory containing PNG images (output of PDF→image conversion, or scanned images)
image_dir: /Volumes/main/default/ocr_data/images

# OCR model: tencent/HunyuanOCR or deepseek-ai/DeepSeek-OCR
ocr_model: deepseek-ai/DeepSeek-OCR

# UC volume for OCR output (Parquet written under this volume)
uc_volume: ocr_data

# Delta table for raw OCR results (one row per page)
ocr_table: main.default.ocr_inference_results

# Delta table written by adapter (one row per document: content, parser_status, doc_uri, last_modified)
# This is the input to 02-chunk-index
parsed_table: main.default.rag_parsed_docs

# --- 02-chunk-index: chunking + Vector Search ---
chunked_table: main.default.rag_docs_chunked
vector_index_name: main.default.rag_docs_chunked_index

# Vector Search (Databricks)
vector_search_endpoint: one-env-shared-endpoint
embedding_endpoint: databricks-bge-m3

# Chunking
chunk_size: 500
chunk_overlap: 50
