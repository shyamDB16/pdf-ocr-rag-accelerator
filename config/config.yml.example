# PDF RAG Solution Accelerator – configuration template
# Copy to config.yml and set values for your environment.
# Used by run scripts; in Databricks you can set these in notebook widgets or the Config cell.

# Unity Catalog
catalog: main
schema: default

# Source PDFs: Unity Catalog volume (Databricks) or local path (external)
volume_name: pdf_docs
# Optional: local path when running outside Databricks (e.g. ./data/pdfs)
# volume_path_local: null

# Delta tables (Unity Catalog three-level names)
parsed_table: main.default.rag_parsed_docs
chunked_table: main.default.rag_docs_chunked
vector_index_name: main.default.rag_docs_chunked_index

# Vector Search (Databricks)
vector_search_endpoint: one-env-shared-endpoint
embedding_endpoint: databricks-bge-m3

# Chunking
chunk_size: 500
chunk_overlap: 50

# Optional: sample PDFs – GitHub repo/path to download if volume is empty (Databricks only)
# sample_pdfs_repo: databricks-demos/dbdemos-dataset
# sample_pdfs_path: /llm/databricks-pdf-documentation
